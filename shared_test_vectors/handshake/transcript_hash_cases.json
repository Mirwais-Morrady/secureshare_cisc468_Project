{
  "test_cases": [
    {
      "id": "transcript_hash_1",
      "description": "Transcript hash with client_hello and server_hello",
      "messages": [
        {
          "type": "ClientHello",
          "data": "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
        },
        {
          "type": "ServerHello",
          "data": "fedcba9876543210fedcba9876543210fedcba9876543210fedcba9876543210"
        }
      ],
      "hash_algorithm": "SHA-256",
      "expected_hash": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"
    },
